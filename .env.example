# Copy to .env.local for local dev (vercel dev), and set the same vars in
# Vercel → Project → Settings → Environment Variables for production.

# API key from https://resend.com (Account → API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where demo enquiries are sent. Multiple recipients allowed, comma-separated.
ENQUIRY_TO_EMAIL=you@kgmedia.id

# Verified sender in Resend (Domains). Must be a verified domain.
# For quick testing only, you may use: onboarding@resend.dev
# (in test mode email is only delivered to the Resend account owner).
ENQUIRY_FROM_EMAIL=Unimind Intelligence <demo@unimind.kgmedia.id>
